:OtherAccount rdfs:subClassOf foaf:Account ;
    rdfs:label "Other" ;
    foaf:icon <urn:profile-pane:starIcon> .

:BlueSkyIdField
    a ui:SingleLineTextField ;
    ui:label "Username";
    ui:maxLength "200" ;
    ui:property foaf:accountName ; 
    ui:pattern "@[a-z0-9A-Z_-](.[a-z0-9A-Z_-])*".

:DiggIdField
    a ui:SingleLineTextField ;
    ui:label "Username";
    ui:maxLength "200" ;
    ui:property foaf:accountName ; 
    ui:pattern "@[a-z0-9A-Z_-](.[a-z0-9A-Z_-])*".

