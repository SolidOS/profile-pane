# an unknown online account needs more info

:OtherIdForm a ui:Group; 
    ui:weight 0; 
    ui:parts ( 
        :OtherIdField 
        :OtherIconField 
        :OtherLabelField ).

:OtherIdField
    a ui:NamedNodeURIField ;
    ui:label "Account link";
    ui:maxLength "200" ;
    ui:property foaf:homepage.

:OtherIconField
    a ui:NamedNodeURIField ;
    ui:label "Icon link";
    ui:maxLength "200" ;
    ui:property foaf:icon.

:OtherLabelField
    a ui:SingleLineTextField ;
    ui:label "Name";
    ui:maxLength "200" ;
    ui:property rdfs:label.

# ends
